rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /artifacts/{appId} {
      // DRIVERS - Strict UID validation
      match /drivers/{driverId} {
        allow read: if request.auth.uid == driverId;
        allow create: if request.auth.uid == request.resource.data.uid 
                     && request.resource.data.registrationComplete == true;
        allow update: if request.auth.uid == driverId 
                     && resource.data.registrationComplete == true;
        allow delete: if false;
      }

      // TRIPS
      match /trips/{driverId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == driverId;
        // Passengers need to decrement seat counts when booking
        allow update: if request.auth != null
                     && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['filledSeats', 'seatsAvailable', 'bookedSeats']);
      }

      // SUBCOLLECTIONS
      match /drivers/{driverId}/expenses/{expenseId} {
        allow read, create, update, delete: if request.auth.uid == driverId;
      }

      match /drivers/{driverId}/wallet_txns/{txnId} {
        allow read, create: if request.auth.uid == driverId;
        allow delete: if false;
      }

      // BOOKINGS
      match /public/data/bookings/{bookingId} {
        allow read: if request.auth.uid == resource.data.userId 
                    || request.auth.uid == resource.data.driverId;
        allow create: if request.auth.uid == request.resource.data.userId;
        allow update: if request.auth.uid == resource.data.driverId 
                      || request.auth.uid == resource.data.userId;
      }

      // PASSENGER PROFILES
      match /public/data/user_profiles/{userId} {
        allow read: if request.auth.uid == userId;
        allow create: if request.auth.uid == request.resource.data.uid 
                     && request.resource.data.registrationComplete == true;
        allow update: if request.auth.uid == userId;
      }
    }
  }
}
