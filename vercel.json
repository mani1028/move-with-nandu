{
  "version": 2,
  "buildCommand": "python -m venv .vercel-venv && .vercel-venv/bin/python -m pip install --upgrade pip setuptools wheel && .vercel-venv/bin/pip install -r backend/requirements.txt && .vercel-venv/bin/python scripts/init_db.py",
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/api/index.py"
    },
    {
      "src": "^/ws/(.*)$",
      "dest": "/api/index.py"
    },
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/public/$1"
    }
  ]
}
