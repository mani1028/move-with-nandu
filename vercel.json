{
  "buildCommand": "",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/favicon.ico", "status": 200, "dest": "/public/favicon.ico" },
    { "src": "/assets/(.*)", "status": 200, "dest": "/public/assets/$1" },
    { "src": "/(.*)\\.html", "status": 200, "dest": "/public/$1.html" },
    { "src": "/$", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/api/index.py" }
  ]
}
