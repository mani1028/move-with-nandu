# ─── JWT & Security ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./nandu.db
# For local Supabase/Postgres testing, override with:
# DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_ID:PASSWORD@aws-X.pooler.supabase.com:6543/postgres

# ─── Admin Credentials ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@nandutravels.com
ADMIN_PASSWORD=Admin@Nandu2026
ADMIN_NAME=Nandu Admin
ADMIN_PHONE=9999999999

# ─── CORS Configuration ───────────────────────────────────────────────────────
# Optional. In production, APP_BASE_URL is used if CORS_ORIGINS is omitted.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000,http://127.0.0.1:8000

# ─── App URL / Deployment ────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000

# ─── Google OAuth 2.0 Configuration ───────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ─── Supabase Storage (used automatically when URL + service role key are set) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROFILE_BUCKET=user-profiles
SUPABASE_DRIVER_DOCS_BUCKET=driver-docs

# ─── Environment ─────────────────────────────────────────────────────────────
# Set to production in prod
ENVIRONMENT=development
